<% provide(:title, @tool.title) %>
<% provide(:icon, @tool.icon_url) %>

<div class="tool-title">
    <i class="white <%= yield(:icon) %>"></i>
    <%= yield(:title) %>
</div>

<div id="result" class="d-none"></div>

<div class="row">
  <div class="col-md-4 col-sm-12">
    <div class="float-end">
      <%= form_with url: get_recipe_path, local: false do |form| %>
        <%= form.label :recipe, class: 'input-group-text' %>
        <%= form.select :recipe, ([""] + @recipes.map { |recipe| [recipe.name,recipe.id]}), { selected: nil }, class: 'form-select inline-edit-select' %>
      <% end %>
    </div>

    <div class="container d-flex flex-row align-items-center flex-wrap">
      <%= form_with url: missions_calculate_path, local: false do |form| %>
        <%= form.submit t('.calculate'), class: "btn btn-primary mb-3", id: "calculate" %>

        <div class="input-group mb-3">
          <%= form.label t('.difficulty'), class: 'input-group-text' %>
          <%= form.select :difficulty, (@options["difficulty"].map { |k, v| [v["name"].capitalize, v["value"]] }.sort_by { |subarray| -subarray[1] }), { selected: 0 }, class: 'form-select' %>
        </div>
        <div class="input-group mb-3">
          <%= form.label t('.tokens'), class: 'input-group-text' %>
          <%= form.number_field :tokens, class: 'form-control', value: 0, step: 1, min: 0, max: 12 %>
        </div>
        <div class="input-group mb-3">
          <%= form.label t('.factors'), class: 'input-group-text' %>
          <%= form.number_field :factors, class: 'form-control', value: 0, step: 1, min: -12, max: 12 %>
        </div>
        <div class="input-group mb-3 ms-3">
          <div class="w-75 ms-1 factor btn btn-sm btn-primary" data-factor="1">◻️ Factor positivo menor</div>
          <div class="w-75 ms-1 factor btn btn-sm btn-primary" data-factor="3"><u>◻️ Factor positivo mayor</u></div>
          <div class="w-75 ms-1 factor btn btn-sm btn-danger" data-factor="-1">◼️ Factor negativo menor</div>
          <div class="w-75 ms-1 factor btn btn-sm btn-danger" data-factor="-3"><u>◼️ Factor negativo mayor</u></div>
        </div>

        <div class="input-group mb-3">
          <%= form.label t('.misc'), class: 'input-group-text' %>
          <%= form.number_field :misc, class: 'form-control', value: 0, step: 1, min: -3, max: 3 %>
        </div>
        <div class="input-group mb-3">
          <%= form.label t('.role'), class: 'input-group-text' %>
          <div class="form-check form-switch switch-group fs-2">
            <%= form.check_box :role, class: 'form-check-input switch-group h-100' %>
          </div>
        </div>
      <% end %>
    </div>
  </div>

  <div class="col-md-8 col-sm-12">
    <div class="container d-flex flex-row align-items-center flex-wrap">
      <%= link_to "Descargar Misiones", sync_missions_path, method: :post, class: 'btn btn-danger ms-1' %>
      <%= link_to "Inicializar Misiones", initialize_missions_path, method: :post, class: 'btn btn-danger d-none' %>
    </div>

    <%= render 'missions_table' %>
  </div>
</div>
