<div class="modal fade" id="missionModal" tabindex="-1" role="dialog" aria-labelledby="Login" aria-hidden="true">
  <div class="modal-dialog modal-lg" role="document">
    <div class="modal-content bg-dark">
      <%= form_with model: mission do |form| %>
        <div class="modal-header">
          <h5 class="modal-title" id="Title"><%= mission.name %></h5>
          <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Close"></button>
        </div>
        <div class="modal-body">
          <div class="input-group mb-3">
            <%= form.label :name, class: 'input-group-text' %>
            <%= form.text_field :name, class: 'form-control', disabled: true  %>
          </div>
          <div class="input-group mb-3">
            <%= form.label :discourse_id, class: 'input-group-text' %>
            <%= form.number_field :discourse_id, class: 'form-control', step: 1, disabled: true %>
          </div>
          <div class="input-group mb-3">
            <%= form.label :status, class: 'input-group-text' %>
            <%= form.text_field :status, class: 'form-control', disabled: true  %>
          </div>
          <div class="input-group mb-3">
            <%= form.label :notes, class: 'input-group-text' %>
            <%= form.text_area :notes, class: 'form-control', rows: 5 %>
          </div>
          <div class="input-group mb-3">
            <%= form.label :started, class: 'input-group-text' %>
            <%= form.date_field :started, class: 'form-control' %>
          </div>
          <div class="input-group mb-3">
            <%= form.label :resolved, class: 'input-group-text' %>
            <%= form.date_field :resolved, class: 'form-control' %>
          </div>

          <%= form.submit nil, class: 'btn btn-primary' %>
        </div>
      <% end %>
  </div>
</div>
